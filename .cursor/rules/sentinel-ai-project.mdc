```bash
# 通过 Maven 运行（项目根目录下执行）
mvn exec:java -pl sentinel-ai-server \
  -Dexec.mainClass=com.zhuangjie.sentinel.knowledge.DdlExporter \
  "-Dexec.args=jdbc:mysql://host:3306/db?user=xxx&password=yyy table-meta/project-name"
