spring:
  datasource:
    driver-class-name: org.postgresql.Driver
    url: jdbc:postgresql://localhost:5432/sentinel_ai
    username: postgres
    password: your-db-password

sentinel:
  ai:
    enabled: true
    model: qwen3.5-plus
    api-key: ${AI_DASHSCOPE_API_KEY:your-dashscope-api-key}
    temperature: 0.2
    max-ai-calls-per-scan: 50
  knowledge:
    table-meta-dir: table-meta
  rag:
    enabled: true
    embedding-model: text-embedding-v3
  data-platform:
    # Set to true only if you have a remote data query platform for DDL collection.
    # When false, manually maintain DDL files in the table-meta directory.
    enabled: false
    sso-url: https://your-sso-server.com
    platform-url: https://your-data-platform.com
    sso-login-path: /your/sso/login/path
    ticket-validate-path: /your/ticket/validate/path
    query-batch-path: /your/query/batch/path
    query-result-path: /your/query/result/path
    platform-name: your-platform
    username: your-encrypted-username
    password: your-encrypted-password
    domain: your-rds-domain.rds.example.com
    database: your-database-name
    collect-batch-size: 30
    diff-batch-size: 30
  git:
    clone-base-dir: ${user.home}/.sentinel-ai/repos
  dev:
    max-sql-per-scan: 50
