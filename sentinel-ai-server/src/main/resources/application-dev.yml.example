spring:
  datasource:
    driver-class-name: org.h2.Driver
    url: jdbc:h2:file:./data/sentinel-ai;MODE=MYSQL;DB_CLOSE_ON_EXIT=FALSE
    username: sa
    password:
  h2:
    console:
      enabled: true
      path: /h2-console
  sql:
    init:
      mode: always
      schema-locations: classpath:db/schema.sql
  ai:
    dashscope:
      api-key: sk-your-real-key-here   # 从 https://dashscope.console.aliyun.com/ 获取

sentinel:
  ai:
    enabled: true      # 设为 false 可关闭 AI 分析（规则引擎仍然运行）
    model: qwen-max    # 可选: qwen-max（更准）/ qwen-turbo（更快更便宜）

logging:
  level:
    com.zhuangjie.sentinel: debug
