spring:
  datasource:
    driver-class-name: org.postgresql.Driver
    url: jdbc:postgresql://localhost:5432/sentinel_ai
    username: postgres
    password: your-db-password
  ai:
    openai:
      api-key: ${AI_DASHSCOPE_API_KEY:your-dashscope-api-key}

sentinel:
  ai:
    enabled: true
    model: qwen3.5-plus
    api-key: ${AI_DASHSCOPE_API_KEY:your-dashscope-api-key}
    temperature: 0.2
    max-ai-calls-per-scan: 50
  knowledge:
    table-meta-dir: table-meta
  rag:
    enabled: true
    embedding-model: text-embedding-v3
  data-platform:
    # Set to true only if you have a remote data query platform for DDL collection.
    # When false, manually maintain DDL files in the table-meta directory.
    enabled: false
    sso-url: https://your-sso-server.com
    platform-url: https://your-data-platform.com
    sso-login-path: /your/sso/login/path
    ticket-validate-path: /your/ticket/validate/path
    query-batch-path: /your/query/batch/path
    query-result-path: /your/query/result/path
    platform-name: your-platform
    username: your-encrypted-username
    password: your-encrypted-password
    domain: your-rds-domain.rds.example.com
    database: your-database-name
    collect-batch-size: 30
    diff-batch-size: 30
  git:
    # NONE / GITLAB / GITHUB — set to your Git platform
    platform: NONE
    api-url: https://your-gitlab-instance.com
    access-token: your-personal-access-token
    clone-base-dir: ${user.home}/.sentinel-ai/repos
  notification:
    # Git username -> WeCom userId mapping file path (relative to project root)
    # See wecom-user-mapping.yml for format. Cached on startup, restart to refresh.
    user-mapping-file: wecom-user-mapping.yml
    wecom:
      # Set to true to enable WeCom group robot notifications and remind feature
      enabled: false
      # WeCom group robot webhook URL
      # Get it from: WeCom Group Chat -> Add Robot -> Custom Robot -> Copy Webhook URL
      webhook-url: https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-robot-key
      # Sentinel AI frontend URL (for notification links)
      frontend-url: http://localhost:8090
  dev:
    max-sql-per-scan: 50
